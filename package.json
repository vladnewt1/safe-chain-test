{
  "name": "safechain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "anchor:build": "anchor build",
    "anchor:deploy": "anchor deploy",
    "anchor:test": "anchor test",
    "test": "anchor test",
    "backup:critical": "powershell -ExecutionPolicy Bypass -File ./scripts/backup-critical.ps1",
    "clean:heavy": "powershell -ExecutionPolicy Bypass -File ./scripts/cleanup-heavy.ps1",
    "dev:box": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-box.ps1",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:dev": "npm --prefix app/frontend run dev",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "concurrently": "^9.2.1",
    "mocha": "^7.2.0",
    "ts-mocha": "^10.1.0",
    "typescript": "^5.8.3"
  }
}
